# ============================================================
# FluxHR — Configurazione Ambiente
# ============================================================
# Copia questo file in .env e personalizza i valori.
# Il file .env NON deve essere committato su Git (già in .gitignore).

# --- DATABASE ---
# Docker Compose (default): usa il container PostgreSQL interno
DATABASE_URL=postgresql://admin:password@localhost:5433/fluxhr

# DB esterno / reale — decommenta e sostituisci con i tuoi dati:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# --- REDIS ---
REDIS_URL=redis://redis:6379/0

# --- SMTP (email Art.14 GDPR) ---
# Sviluppo: MailHog (mock locale)
SMTP_SERVER=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=privacy@fluxhr.com

# Produzione: esempio con Gmail/SMTP reale
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tua.email@gmail.com
# SMTP_PASSWORD=app_password_qui
# FROM_EMAIL=privacy@tuaazienda.com

# --- SICUREZZA JWT ---
# Cambia questo valore in produzione con una stringa casuale lunga!
SECRET_KEY=your-secret-key-change-in-production
